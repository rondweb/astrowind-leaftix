---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Leaftix',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[{ text: 'Explore Solutions', href: '#features', variant: 'primary', class: 'px-5 md:px-6 h-10 md:h-12' }]}
  >
    <Fragment slot="title">
      Empowering Growers with Precision Agriculture
    </Fragment>

    <Fragment slot="subtitle">
      Leaftix provides innovative solutions to optimize crop yields, enhance sustainability, and improve profitability for growers of all sizes.
    </Fragment>
  </Hero>

  <!-- Features Widget *************** -->

  <Features
    id="features"
    classes={{
      container: 'max-w-[960px]',
      headline: {
        container: 'max-w-[720px] md:mx-0 md:text-left text-left mb-8',
        title: 'text-[2rem] md:text-5xl leading-tight tracking-[-0.02em]',
        subtitle: 'text-base text-default mt-3 leading-relaxed',
      },
      items: {
        container: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4',
      },
    }}
    tagline="Our Core Technology Pillars"
    title="Comprehensive Solutions for Every Growing Environment"
    subtitle="Leaftix offers a suite of integrated solutions tailored to different agricultural settings, from field production to indoor cultivation and pasture management."
    items={[
      {
        title: 'Leaftix Grow',
        description:
          'Optimize field crop production with data-driven insights and precision farming tools.',
        icon: 'tabler:plant',
      },
      {
        title: 'Leaftix Microgreens',
        description:
          'Revolutionize indoor microgreens cultivation with smart monitoring and control systems.',
        icon: 'tabler:home',
      },
      {
        title: 'Leaftix Greenpast',
        description:
          'Enhance pasture management with tools for optimizing grazing and livestock health.',
        icon: 'tabler:flower',
      },
      {
        title: 'Leaftix Consulting',
        description:
          'Leverage our expertise to develop customized solutions for your specific needs and challenges.',
        icon: 'tabler:settings',
      },
    ]}
  />

  <!-- About Us Section ************** -->

  <CallToAction
    id="about-us"
    classes={{
      container: 'max-w-[960px] pt-2',
    }}
    title="Welcome to Leaftix"
    subtitle="Where we revolutionize agriculture with cutting-edge technology. Our mission is to provide modern, accessible, and useful technologies that optimize processes, reduce production costs, and promote environmental stewardship. With a suite of products and services for smart farming we empower farmers to enhance productivity and profitability while safeguarding the planet.<br /><br />Guided by our values of modernity, transparency, and sustainability, Leaftix aims to lead in agricultural innovation. By addressing the challenges of inefficient and unsustainable practices, we create value for our customers, partners, employees, and shareholders, contributing to the well-being of the communities we serve.<br /><br />Explore how Leaftix can transform your farming operations and join us in our commitment to a sustainable and prosperous future."
    actions={[
      { text: 'More Information', href: '/about', variant: 'secondary' },
      { text: 'Explore Solutions', href: '#features', variant: 'primary' },
    ]}
  >
    <Fragment slot="content">
      <div class="w-full max-w-3xl mx-auto overflow-hidden rounded-xl border border-[#cfe2e7] shadow-lg">
        <div class="relative w-full pt-[56.25%]">
          <iframe
            class="absolute inset-0 h-full w-full"
            src="https://www.youtube.com/embed/GpOW09_BJUU"
            title="Leaftix Institutional Video"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </Fragment>
  </CallToAction>

  <CallToAction
    classes={{
      container: 'max-w-[960px] pt-4 md:pt-8',
    }}
    title="Ready to Transform Your Growing Operation?"
    subtitle="Contact us today to learn more about how Leaftix can help you achieve your goals."
    actions={[{ text: 'Get Started', href: '/contact', variant: 'primary', class: 'px-5 md:px-6 h-10 md:h-12' }]}
  />
</Layout>
