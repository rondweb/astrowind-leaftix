---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'AstroWind — Free template for creating websites with Astro + Tailwind CSS',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[{ text: "Explore Solutions", href: "#" }]}
  >
    <Fragment slot="title">
      Empowering Growers with Precision Agriculture
    </Fragment>

    <Fragment slot="subtitle">
      Leaftix provides innovative solutions to optimize crop yields, enhance sustainability, and improve profitability for growers of all sizes.
    </Fragment>
  </Hero>

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Core Technology Pillars"
    title="Comprehensive Solutions for Every Growing Environment"
    subtitle="Leaftix offers a suite of integrated solutions tailored to different agricultural settings, from field production to indoor cultivation and pasture management."
    items={[
      {
        title: 'Leaftix Grow',
        description:
          'Optimize field crop production with data-driven insights and precision farming tools.',
        icon: 'tabler:plant',
      },
      {
        title: 'Leaftix Microgreens',
        description:
          'Revolutionize indoor microgreens cultivation with smart monitoring and control systems.',
        icon: 'tabler:house',
      },
      {
        title: 'Leaftix Greenpast',
        description:
          'Enhance pasture management with tools for optimizing grazing and livestock health.',
        icon: 'tabler:flower',
      },
      {
        title: 'Leaftix Consulting',
        description:
          'Leverage our expertise to develop customized solutions for your specific needs and challenges.',
        icon: 'tabler:gear',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features
    tagline="Microgreens Solutions"
    title="Tailored Packages for Microgreens Growers"
    subtitle="Leaftix Microgreens offers specialized packages designed to meet the unique needs of microgreens producers, from small-scale startups to large commercial
    operations."
    items={[
      {
        title: 'Starter Package',
        description: "Ideal for new microgreens growers, providing essential monitoring and control features.",
        icon: 'tabler:package',
      },
      {
        title: 'Professional Package',
        description:
          "Designed for established growers seeking advanced automation and optimization tools.",
        icon: 'tabler:package',
      },
      {
        title: 'Enterprise Package',
        description:
          'Comprehensive solution for large-scale operations, including custom integrations and support.',
        icon: 'tabler:package',
      },
    ]}
  />

  <Features2
      tagline="Microgreens Use Cases"
      title="Real-World Applications of Leaftix Microgreens"
      subtitle="See how Leaftix Microgreens is helping growers achieve higher yields, reduce costs, and improve product quality."
      items={[
          {
              title: 'Yield Optimization',
              description: 'Increase microgreens yields by optimizing growing conditions and resource utilization.',
              icon: 'tabler:chart-line',
          },
          {
              title: 'Resource Efficiency',
              description: 'Reduce water and energy consumption through precise monitoring and automated controls.',
              icon: 'tabler:clock-counter-clockwise',
          },
          {
              title: 'Quality Control',
              description: 'Maintain consistent product quality and meet market demands with real-time data and insights.',
              icon: 'tabler:plant',
          },
      ]}
  >
  </Features2>
</Layout>
