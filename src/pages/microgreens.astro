---
import Layout from '~/layouts/PageLayout.astro';

import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Microgreens',
};
---

<Layout metadata={metadata}>
  <Features
    id="microgreens-solutions"
    classes={{
      container: 'max-w-[960px]',
      headline: {
        container: 'max-w-[720px] md:mx-0 md:text-left text-left mb-8',
        title: 'text-[2rem] md:text-5xl leading-tight tracking-[-0.02em]',
        subtitle: 'text-base text-default mt-3 leading-relaxed',
      },
      items: {
        container: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
      },
    }}
    tagline="Microgreens Solutions"
    title="Tailored Packages for Microgreens Growers"
    subtitle="Leaftix Microgreens offers specialized packages designed to meet the unique needs of microgreens producers, from small-scale startups to large commercial operations."
    items={[
      {
        title: 'Starter Package',
        description: 'Ideal for new microgreens growers, providing essential monitoring and control features.',
        icon: 'tabler:package',
      },
      {
        title: 'Professional Package',
        description: 'Designed for established growers seeking advanced automation and optimization tools.',
        icon: 'tabler:package',
      },
      {
        title: 'Enterprise Package',
        description: 'Comprehensive solution for large-scale operations, including custom integrations and support.',
        icon: 'tabler:package',
      },
    ]}
  />

  <Features2
    id="microgreens-use-cases"
    classes={{
      container: 'max-w-[960px]',
      headline: {
        container: 'max-w-[720px] md:mx-0 md:text-left text-left mb-8',
        title: 'text-[2rem] md:text-5xl leading-tight tracking-[-0.02em]',
        subtitle: 'text-base text-default mt-3 leading-relaxed',
      },
      items: {
        container: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
      },
    }}
    tagline="Microgreens Use Cases"
    title="Real-World Applications of Leaftix Microgreens"
    subtitle="See how Leaftix Microgreens is helping growers achieve higher yields, reduce costs, and improve product quality."
    items={[
      {
        title: 'Yield Optimization',
        description: 'Increase microgreens yields by optimizing growing conditions and resource utilization.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Resource Efficiency',
        description: 'Reduce water and energy consumption through precise monitoring and automated controls.',
        icon: 'tabler:history',
      },
      {
        title: 'Quality Control',
        description: 'Maintain consistent product quality and meet market demands with real-time data and insights.',
        icon: 'tabler:plant',
      },
    ]}
  />

  <CallToAction
    classes={{
      container: 'max-w-[960px] pt-4 md:pt-8',
    }}
    title="Ready to Transform Your Microgreens Operation?"
    subtitle="Talk to our team and discover the right package for your farm."
    actions={[{ text: 'Get Started', href: '/contact', variant: 'primary', class: 'px-5 md:px-6 h-10 md:h-12' }]}
  />
</Layout>
